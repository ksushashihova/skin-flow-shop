# --- Postgres (Timeweb managed) ---
DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=require

# --- better-auth ---
# Сгенерировать: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-32+chars
BETTER_AUTH_URL=https://example.ru

# --- S3 (Timeweb Cloud Storage) ---
S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_BUCKET=oblako
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://oblako.s3.timeweb.cloud

# --- SMTP (Yandex/Mail.ru/Timeweb) ---
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.ru
SMTP_PASS=
SMTP_FROM="ОБЛАКО <noreply@example.ru>"
